{
  "name": "@dujavi/ai-md",
  "version": "0.6.1",
  "description": "AXI-shaped CLI for private ~/.ai-md: shared+agents build to dist, multi-harness link (Cursor, Claude, agents, …)",
  "bin": {
    "ai-md": "bin/ai-md.js"
  },
  "files": [
    "bin/",
    "lib/",
    "scripts/",
    "skeleton/",
    "docs/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "test": "node bin/ai-md.js --help && node bin/ai-md.js harness list --json >/dev/null && node bin/ai-md.js status --json >/dev/null"
  },
  "dependencies": {
    "@toon-format/toon": "^2.3.1"
  },
  "keywords": [
    "axi",
    "cursor",
    "claude",
    "agents",
    "skills",
    "rules",
    "personal-config",
    "cli",
    "toon",
    "ai-md"
  ],
  "author": "dujavi",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dujavi/ai-md.git"
  },
  "bugs": {
    "url": "https://github.com/dujavi/ai-md/issues"
  },
  "homepage": "https://github.com/dujavi/ai-md#readme",
  "publishConfig": {
    "access": "public"
  }
}
